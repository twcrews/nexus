@inject IDataProvider DataProvider
@inject RefreshService RefreshService
@inject SessionTokenStore TokenStore
@inject IHttpClientFactory HttpClientFactory
@implements IDisposable
@using System.Text.Json
@using Microsoft.TeamFoundation.SourceControl.WebApi
@using Microsoft.TeamFoundation.WorkItemTracking.WebApi
@using Microsoft.VisualStudio.Services.Common
@using Microsoft.VisualStudio.Services.WebApi

<PageTitle>Nexus</PageTitle>

@if (!_loaded)
{
    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="height:60vh;">
        <MudProgressCircular Indeterminate="true" Size="Size.Large" />
    </MudStack>
}
else if (!_hasAccounts)
{
    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="3" Style="height:60vh;">
        <MudIcon Icon="@MudBlazor.FontIcons.MaterialSymbols.Outlined.NoAccounts" Style="font-size:120px; opacity:0.6;" />
        <MudText Typo="Typo.h6" Style="opacity:0.6;">No accounts added yet</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="@OnOpenSettings">Add account</MudButton>
    </MudStack>
}
else
{
    <div style="padding:16px;max-width:1600px;margin:0 auto;">
        <MudGrid Spacing="4" Style="margin-bottom:24px;">
            <MudItem xs="6" md="3">
                <MetricCard Count="@_workItems.Count(wi => wi.Assignee != null)" Label="work items assigned to you"
                            Icon="@MudBlazor.FontIcons.MaterialSymbols.Outlined.AssignmentInd" />
            </MudItem>
            <MudItem xs="6" md="3">
                <MetricCard Count="@_workItems.Count(wi => wi.Assignee == null)" Label="unassigned work items"
                            Icon="@MudBlazor.FontIcons.MaterialSymbols.Outlined.AssignmentLate" />
            </MudItem>
            <MudItem xs="6" md="3">
                <MetricCard Count="@_pullRequests.Count(pr => pr.IsAssignedToCurrentUser)" Label="PRs assigned to you"
                            Icon="@MudBlazor.FontIcons.MaterialSymbols.Outlined.PersonEdit" />
            </MudItem>
            <MudItem xs="6" md="3">
                <MetricCard Count="@_pullRequests.Count(pr => !pr.IsAssignedToCurrentUser)" Label="unassigned PRs"
                            Icon="@MudBlazor.FontIcons.MaterialSymbols.Outlined.RebaseEdit" />
            </MudItem>
        </MudGrid>
        <MudGrid Spacing="4">
            <MudItem xs="12" lg="6">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween"
                          Style="margin-bottom:4px;">
                    <MudText Typo="Typo.h5">Work Items</MudText>
                    <div style="width:220px;">
                        <MudTextField T="string" @bind-Value="_workItemSearch" Placeholder="Search..."
                                      Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search" Clearable="true" Immediate="true" />
                    </div>
                </MudStack>
                <WorkItemList Items="_workItems" SearchTerm="@_workItemSearch"
                             AssignedItemIds="@_assignedWorkItemIds"
                             FetchDetails="@FetchWorkItemDetailsAsync" />
            </MudItem>
            <MudItem xs="12" lg="6">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween"
                          Style="margin-bottom:4px;">
                    <MudText Typo="Typo.h5">Pull Requests</MudText>
                    <div style="width:220px;">
                        <MudTextField T="string" @bind-Value="_prSearch" Placeholder="Search..." Variant="Variant.Outlined"
                                      Margin="Margin.Dense" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                                      Clearable="true" Immediate="true" />
                    </div>
                </MudStack>
                <PullRequestList Items="_pullRequests" SearchTerm="@_prSearch"
                                AssignedPrIds="@_assignedPrIds"
                                FetchDescription="@FetchPrDescriptionAsync" />
            </MudItem>
        </MudGrid>
    </div>
}

@code {
    [Parameter] public EventCallback OnOpenSettings { get; set; }

    private bool _loaded;
    private bool _hasAccounts;
    private IEnumerable<WorkItem> _workItems = [];
    private IEnumerable<PullRequest> _pullRequests = [];

    private HashSet<string> _assignedWorkItemIds = [];
    private HashSet<string> _assignedPrIds = [];

    private string? _workItemSearch;
    private string? _prSearch;

    private CancellationTokenSource _cts = new();

    protected override void OnInitialized()
    {
        TokenStore.AccountsChanged += OnAccountsChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await TokenStore.LoadAsync();
        await RefreshAsync();
        _loaded = true;
        StateHasChanged();
        _ = RunRefreshLoopAsync(_cts.Token);
    }

    private async Task RefreshAsync()
    {
        _hasAccounts = TokenStore.GetLinkedAccounts() is { } accounts
            && (accounts.GitHubAccounts.Count > 0 || accounts.MicrosoftAccounts.Count > 0);
        var data = await DataProvider.GetDashboardDataAsync();
        _workItems = data.WorkItems.OrderBy(wi => wi.Assignee == null).ThenByDescending(wi => wi.UpdatedAt);
        _pullRequests = data.PullRequests;
        _assignedWorkItemIds = _workItems.Where(wi => wi.Assignee != null).Select(x => x.Id).ToHashSet();
        _assignedPrIds = _pullRequests.Where(pr => pr.IsAssignedToCurrentUser || pr.WasCreatedByCurrentUser).Select(x => x.Id).ToHashSet();
        RefreshService.NotifyRefreshed();
    }

    private void OnAccountsChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await RefreshAsync();
            StateHasChanged();
        });
    }

    private async Task RunRefreshLoopAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(60));
        while (await timer.WaitForNextTickAsync(ct))
        {
            await RefreshAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<WorkItemDetails?> FetchWorkItemDetailsAsync(WorkItem wi)
    {
        if (wi.Url is not { } url) return null;
        if (!Uri.TryCreate(url, UriKind.Absolute, out var uri)) return null;

        if (uri.Host.Equals("github.com", StringComparison.OrdinalIgnoreCase))
            return await FetchGitHubIssueDetailsAsync(uri);

        var path = uri.AbsolutePath.TrimStart('/');
        var wiIdx = path.IndexOf("/_workitems/edit/", StringComparison.Ordinal);
        if (wiIdx < 0) return null;

        var beforeWi = path[..wiIdx];
        var afterEdit = path[(wiIdx + "/_workitems/edit/".Length)..];
        if (!int.TryParse(afterEdit.Split('/')[0], out var wiId)) return null;

        string orgUrl, projectName;
        if (uri.Host.Equals("dev.azure.com", StringComparison.OrdinalIgnoreCase))
        {
            var slashIdx = beforeWi.IndexOf('/');
            if (slashIdx < 0) return null;
            orgUrl = $"{uri.Scheme}://dev.azure.com/{beforeWi[..slashIdx]}";
            projectName = Uri.UnescapeDataString(beforeWi[(slashIdx + 1)..]);
        }
        else
        {
            orgUrl = $"{uri.Scheme}://{uri.Host}";
            projectName = Uri.UnescapeDataString(beforeWi);
        }

        var token = TokenStore.GetLinkedAccounts().MicrosoftAccounts
            .FirstOrDefault(a => string.Equals(
                a.OrgUrl.TrimEnd('/'), orgUrl.TrimEnd('/'), StringComparison.OrdinalIgnoreCase));
        if (token is null) return null;

        try
        {
            var connection = new VssConnection(new Uri(orgUrl), new VssBasicCredential(string.Empty, token.PersonalAccessToken));
            var client = await connection.GetClientAsync<WorkItemTrackingHttpClient>();

            string[] fields = [
                "Microsoft.VSTS.Common.AcceptanceCriteria",
                "Microsoft.VSTS.Common.Priority",
                "System.IterationPath",
                "System.AreaPath",
                "Microsoft.VSTS.Scheduling.StoryPoints",
                "Microsoft.VSTS.Scheduling.Effort",
                "Microsoft.VSTS.Scheduling.RemainingWork",
                "System.Parent",
            ];

            var item = await client.GetWorkItemAsync(wiId, fields);
            string? Get(string field) => item.Fields.TryGetValue(field, out var v) ? v?.ToString() : null;

            var storyPoints = Get("Microsoft.VSTS.Scheduling.StoryPoints");
            var effort = Get("Microsoft.VSTS.Scheduling.Effort");
            var effortDisplay = storyPoints is not null ? $"{storyPoints} pts"
                              : effort is not null ? $"{effort} h"
                              : null;

            var remainingWork = Get("Microsoft.VSTS.Scheduling.RemainingWork");

            var parentId = Get("System.Parent");
            var parentUrl = parentId is not null
                ? $"{orgUrl.TrimEnd('/')}/{Uri.EscapeDataString(projectName)}/_workitems/edit/{parentId}"
                : null;

            return new WorkItemDetails(
                AcceptanceCriteria: Get("Microsoft.VSTS.Common.AcceptanceCriteria"),
                Priority: Get("Microsoft.VSTS.Common.Priority"),
                IterationPath: Get("System.IterationPath"),
                AreaPath: Get("System.AreaPath"),
                Effort: effortDisplay,
                RemainingWork: remainingWork is not null ? $"{remainingWork} h" : null,
                ParentId: parentId,
                ParentUrl: parentUrl);
        }
        catch
        {
            return null;
        }
    }

    private async Task<WorkItemDetails?> FetchGitHubIssueDetailsAsync(Uri uri)
    {
        var segments = uri.AbsolutePath.Trim('/').Split('/');
        if (segments.Length < 4 || !segments[2].Equals("issues", StringComparison.OrdinalIgnoreCase)) return null;
        if (!int.TryParse(segments[3], out var number)) return null;
        var owner = segments[0];
        var repo = segments[1];

        var ghToken = TokenStore.GetLinkedAccounts().GitHubAccounts
            .FirstOrDefault(a => a.MonitoredRepos.Any(r =>
                r.Equals($"{owner}/{repo}", StringComparison.OrdinalIgnoreCase)))
            ?? TokenStore.GetLinkedAccounts().GitHubAccounts.FirstOrDefault();
        if (ghToken is null) return null;

        try
        {
            var client = HttpClientFactory.CreateClient("GitHub");
            client.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", ghToken.PersonalAccessToken);

            using var response = await client.GetAsync($"repos/{owner}/{repo}/issues/{number}");
            if (!response.IsSuccessStatusCode) return null;

            using var doc = await JsonDocument.ParseAsync(await response.Content.ReadAsStreamAsync());
            var root = doc.RootElement;

            string? milestone = null;
            if (root.TryGetProperty("milestone", out var ms) && ms.ValueKind == JsonValueKind.Object
                && ms.TryGetProperty("title", out var mt))
                milestone = mt.GetString();

            int? commentCount = null;
            if (root.TryGetProperty("comments", out var cc))
                commentCount = cc.GetInt32();

            return new WorkItemDetails(Milestone: milestone, CommentCount: commentCount);
        }
        catch
        {
            return null;
        }
    }

    private async Task<string?> FetchPrDescriptionAsync(PullRequest pr)
    {
        if (pr.Url is null) return null;
        if (!Uri.TryCreate(pr.Url, UriKind.Absolute, out var uri)) return null;

        var path = uri.AbsolutePath.TrimStart('/');
        var gitIdx = path.IndexOf("/_git/", StringComparison.Ordinal);
        var prIdx = path.IndexOf("/pullrequest/", StringComparison.Ordinal);
        if (gitIdx < 0 || prIdx < 0) return null;
        if (!int.TryParse(path[(prIdx + "/pullrequest/".Length)..].Split('/')[0], out var prId)) return null;

        var beforeGit = path[..gitIdx];
        var project = Uri.UnescapeDataString(beforeGit[(beforeGit.LastIndexOf('/') + 1)..]);
        var repo = Uri.UnescapeDataString(path[(gitIdx + "/_git/".Length)..prIdx]);
        var orgUrl = uri.Host == "dev.azure.com"
            ? $"{uri.Scheme}://{uri.Host}/{beforeGit[..beforeGit.IndexOf('/')]}"
            : $"{uri.Scheme}://{uri.Host}";

        var token = TokenStore.GetLinkedAccounts().MicrosoftAccounts
            .FirstOrDefault(a => string.Equals(
                a.OrgUrl.TrimEnd('/'), orgUrl.TrimEnd('/'), StringComparison.OrdinalIgnoreCase));
        if (token is null) return null;

        try
        {
            var connection = new VssConnection(new Uri(orgUrl), new VssBasicCredential(string.Empty, token.PersonalAccessToken));
            var client = await connection.GetClientAsync<GitHttpClient>();
            var full = await client.GetPullRequestAsync(project, repo, prId);
            return full.Description;
        }
        catch
        {
            return null;
        }
    }

    public void Dispose()
    {
        TokenStore.AccountsChanged -= OnAccountsChanged;
        _cts.Cancel();
    }
}
