<MudTooltip Text="@DisplayName">
    @if (!string.IsNullOrEmpty(User.AvatarUrl))
    {
        <img src="@User.AvatarUrl" alt="@User.Name"
             style="width:24px;height:24px;border-radius:50%;object-fit:cover;flex-shrink:0;cursor:default;" />
    }
    else
    {
        <MudAvatar Size="Size.Small" Style="width:24px;height:24px;font-size:0.75rem;">@DisplayName[..1]</MudAvatar>
    }
</MudTooltip>

@code {
    [Parameter, EditorRequired] public UserReference User { get; set; } = null!;

    private string DisplayName
    {
        get
        {
            var name = User.Name;
            var comma = name.IndexOf(',');
            if (comma <= 0) return name;
            var last = name[..comma].Trim();
            var first = name[(comma + 1)..].Trim();
            return string.IsNullOrEmpty(first) ? last : $"{first} {last}";
        }
    }
}
