<MudDataGrid Elevation="0" Class="bordered" T="PullRequest" Items="@_items" SortMode="SortMode.Multiple" Hover="true" Dense="true">
    <NoRecordsContent>
        <MudText Typo="Typo.body2" Style="opacity:0.5;padding:1rem;">No pull requests.</MudText>
    </NoRecordsContent>
    <Columns>
        <TemplateColumn T="PullRequest" Title="Status" SortBy="@(x => x.Status)">
            <CellTemplate>
                <MudChip T="string" Text="@context.Item.Status.ToString()"
                         Color="@StatusColor(context.Item.Status)"
                         Variant="Variant.Filled" Size="Size.Small" />
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn T="PullRequest" Title="ID" SortBy="@(x => x.Id)">
            <CellTemplate>
                <span style="font-size:0.75rem;font-family:'JetBrains Mono',monospace;opacity:0.6;">
                    @context.Item.Id
                </span>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn T="PullRequest" Title="Title" SortBy="@(x => x.Title)">
            <CellTemplate>
                <MudStack Spacing="1">
                    <ScrollText>@context.Item.Title</ScrollText>
                    <ScrollText>
                        <span style="font-size:0.7rem;opacity:0.55;font-family:'JetBrains Mono',monospace;">
                            @context.Item.Source.Repository/@context.Item.Source.Branch → @context.Item.Target.Branch
                        </span>
                    </ScrollText>
                </MudStack>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn T="PullRequest" Title="Creator" Sortable="false">
            <CellTemplate>
                <UserPill User="context.Item.Creator" />
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn T="PullRequest" Title="Reviewers" Sortable="false">
            <CellTemplate>
                @if (context.Item.Reviewers.Count == 0)
                {
                    <span style="opacity:0.35;">—</span>
                }
                else
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <UserPill User="context.Item.Reviewers[0]" />
                        @if (context.Item.Reviewers.Count > 1)
                        {
                            <span style="font-size:0.75rem;opacity:0.55;">+@(context.Item.Reviewers.Count - 1)</span>
                        }
                    </MudStack>
                }
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn T="PullRequest" Title="Updated" SortBy="@(x => x.UpdatedAt)">
            <CellTemplate>
                <span style="font-size:0.75rem;opacity:0.6;">@Relative(context.Item.UpdatedAt)</span>
            </CellTemplate>
        </TemplateColumn>
    </Columns>
</MudDataGrid>

@code {
    [Parameter, EditorRequired] public IEnumerable<PullRequest>? Items { get; set; }

    private List<PullRequest> _items => Items?.ToList() ?? [];

    private static Color StatusColor(PullRequestStatus s) => s switch
    {
        PullRequestStatus.Draft  => Color.Default,
        PullRequestStatus.Open   => Color.Primary,
        PullRequestStatus.Merged => Color.Success,
        PullRequestStatus.Closed => Color.Default,
        _                        => Color.Secondary,
    };

    private static string Relative(DateTimeOffset dt)
    {
        var d = DateTimeOffset.UtcNow - dt;
        if (d.TotalDays >= 1)  return $"{(int)d.TotalDays}d ago";
        if (d.TotalHours >= 1) return $"{(int)d.TotalHours}h ago";
        return $"{(int)d.TotalMinutes}m ago";
    }
}
