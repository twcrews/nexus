@inject IJSRuntime JS
@using Markdig
@using Nexus.Services

<MudDataGrid Elevation="0" Class="bordered" T="PullRequest" Items="@_items" SortMode="SortMode.Single" Hover="true"
             RowClick="@OnRowClick" RowStyleFunc="@RowStyle" RowClassFunc="@RowClass">
    <NoRecordsContent>
        <MudText Typo="Typo.body2" Style="opacity:0.5;padding:1rem;">No pull requests.</MudText>
    </NoRecordsContent>
    <ColGroup>
        <col style="width: 5%;" />
        <col style="width: 10%;" />
        <col style="width: 75%;" />
        <col style="width: 10%;" />
    </ColGroup>
    <Columns>
        <HierarchyColumn T="PullRequest" />
        <PropertyColumn Property="x => x.Id" Title="ID">
            <CellTemplate>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudTooltip Text="@context.Item.Creator.DisplayName">
                        <MudAvatar Size="Size.Small">
                            <MudImage Src="@context.Item.Creator.AvatarUrl" Alt="@context.Item.Creator.Name" />
                        </MudAvatar>
                    </MudTooltip>
                    <span style="font-size:0.75rem;font-family:'JetBrains Mono',monospace;opacity:0.6;">
                        @context.Item.Id
                    </span>
                </MudStack>
            </CellTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Title" Title="Title">
            <CellTemplate>
                <MudStack Spacing="0">
                    <ScrollText>@context.Item.Title</ScrollText>
                    <ScrollText>
                        <span style="font-size:0.7rem;opacity:0.55;font-family:'JetBrains Mono',monospace;">
                            @(context.Item.Source.Repository != context.Item.Target.Repository ?
                            $"{context.Item.Source.Repository}/{context.Item.Source.Branch}" :
                            context.Item.Source.Branch) → @context.Item.Target.Branch
                        </span>
                    </ScrollText>
                </MudStack>
            </CellTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.UpdatedAt" Title="Updated">
            <CellTemplate>
                <span style="font-size:0.75rem;opacity:0.6;">@Relative(context.Item.UpdatedAt)</span>
            </CellTemplate>
        </PropertyColumn>
    </Columns>
    <ChildRowContent>
        @{
            var pr = context.Item;
            EnsureDescriptionLoaded(pr);
            var desc = (_fetchedDescriptions.TryGetValue(pr.Id, out var d) ? d : null) ?? pr.Description;
        }
        <div style="padding:0.75rem 1rem 0.75rem 2.5rem;display:flex;flex-direction:column;gap:0.5rem;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                <MudText Typo="Typo.h6">
                    @if (pr.Url is not null)
                    {
                        <a href="@pr.Url" target="_blank" style="color:inherit;text-decoration:none;" onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'">@pr.Title</a>
                    }
                    else
                    {
                        @pr.Title
                    }
                    <MudChip Size="Size.Small">@pr.Target.Repository</MudChip>
                </MudText>
                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                    @if (pr.Status == PullRequestStatus.Draft)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Icon="@Icons.Material.Filled.EditNote"
                                 Style="width:fit-content;">Draft</MudChip>
                    }
                    @if (pr.MergeStatus is { } ms)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Error"
                                 Icon="@Icons.Material.Filled.MergeType" Style="width:fit-content;">@ms</MudChip>
                    }
                    @if (pr.AutoComplete)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info"
                                 Icon="@Icons.Material.Filled.AutoMode" Style="width:fit-content;">Auto-complete</MudChip>
                    }
                </MudStack>
            </MudStack>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Wrap="Wrap.Wrap">
                <span
                    style="font-size:0.75rem;font-family:'JetBrains Mono',monospace;opacity:0.6;">@(pr.Source.Repository
                                        != pr.Target.Repository ? pr.Source.Repository + "/" : "")@(pr.Source.Branch)</span>
                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Style="opacity:0.4;" />
                    <span
                    style="font-size:0.75rem;font-family:'JetBrains Mono',monospace;opacity:0.6;">@pr.Target.Branch</span>
                </MudStack>
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                    @if (pr.Assignees.Count > 0)
                    {
                        <MudText Typo="Typo.caption" Style="opacity:0.5;min-width:4rem;">Assignees:</MudText>
                        @foreach (var user in pr.Assignees)
                        {
                            <Avatar User="@user" />
                        }
                    }
                    else if (pr.Reviewers.Count == 0)
                    {
                        <MudChip T="string" Color="Color.Tertiary" Size="Size.Small" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Warning" Style="font-weight:700;">UNASSIGNED</MudChip>
                    }
                    @if (pr.Reviewers.Count > 0)
                    {
                        @if (pr.Assignees.Count > 0)
                        {
                            <MudDivider Vertical="true" FlexItem="true" Style="margin:0 0.25rem;" />
                        }
                        <MudText Typo="Typo.caption" Style="opacity:0.5;min-width:4rem;">Reviewers:</MudText>
                        @foreach (var reviewer in pr.Reviewers)
                        {
                            <Avatar User="@reviewer.User" Vote="@reviewer.Vote" />
                        }
                    }
                </MudStack>
                @if (pr.Labels is { Count: > 0 })
                {
                    <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                        @foreach (var label in pr.Labels)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default"
                                     Style="width:fit-content;">@label</MudChip>
                        }
                    </MudStack>
                }
                @if (_loadingDescriptions.Contains(pr.Id))
                {
                    <MudProgressLinear Indeterminate="true" />
                }
                else if (!string.IsNullOrWhiteSpace(desc))
                {
                    <div class="prerendered-description">@((MarkupString)RenderMarkdown(desc))</div>
                }
                @if (pr.LinkedWorkItemIds is { Count: > 0 })
                {
                    <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.caption" Style="opacity:0.5;">Work items:</MudText>
                        @foreach (var id in pr.LinkedWorkItemIds)
                        {
                            var url = pr.LinkedWorkItemUrls?.GetValueOrDefault(id);
                            <MudChip T="string" Size="Size.Small" Color="Color.Default"
                                     Href="@url" Target="@(url is not null ? "_blank" : null)">#@id</MudChip>
                        }
                    </MudStack>
                }
                <MudText Typo="Typo.caption" Style="opacity:0.4;">
                    Opened @pr.CreatedAt.ToString("MMM d, yyyy") by @pr.Creator.DisplayName
                </MudText>
            </div>
        </ChildRowContent>
    </MudDataGrid>

@code {
    [Parameter, EditorRequired] public IEnumerable<PullRequest>? Items { get; set; }
    [Parameter] public string? SearchTerm { get; set; }
    [Parameter] public HashSet<string>? AssignedPrIds { get; set; }
    [Parameter] public Func<PullRequest, Task<string?>>? FetchDescription { get; set; }

    // Stable object references keyed by ID so MudDataGrid's internal OpenHierarchies
    // set keeps valid references across data refreshes, preserving expanded row state.
    private readonly Dictionary<string, PullRequest> _stableItems = new();

    private readonly Dictionary<string, string?> _fetchedDescriptions = new();
    private readonly HashSet<string> _loadingDescriptions = new();

    public override async Task SetParametersAsync(ParameterView parameters)
    {
        if (parameters.TryGetValue<IEnumerable<PullRequest>?>(nameof(Items), out var newItems))
        {
            if (newItems is not null)
            {
                var freshIds = newItems.Select(x => x.Id).ToHashSet();
                foreach (var id in _stableItems.Keys.Except(freshIds).ToList())
                    _stableItems.Remove(id);
                foreach (var pr in newItems)
                    _stableItems.TryAdd(pr.Id, pr);
            }
            else
            {
                _stableItems.Clear();
            }
        }
        await base.SetParametersAsync(parameters);
    }

    private void EnsureDescriptionLoaded(PullRequest pr)
    {
        if (FetchDescription is null) return;
        if (_fetchedDescriptions.ContainsKey(pr.Id) || _loadingDescriptions.Contains(pr.Id)) return;
        _loadingDescriptions.Add(pr.Id);
        _ = InvokeAsync(async () =>
        {
            try
            {
                _fetchedDescriptions[pr.Id] = await FetchDescription(pr);
            }
            catch
            {
                _fetchedDescriptions[pr.Id] = null;
            }
            finally
            {
                _loadingDescriptions.Remove(pr.Id);
                StateHasChanged();
            }
        });
    }

    private string? RowStyle(PullRequest item, int _) =>
        item.Url is not null ? "cursor:pointer;" : null;

    private string RowClass(PullRequest item, int _) =>
        AssignedPrIds?.Contains(item.Id) == true ? "assigned-row" : "";

    private List<PullRequest> _items
    {
        get
        {
            if (_stableItems.Count == 0) return [];
            var source = _stableItems.Values;
            var filtered = string.IsNullOrWhiteSpace(SearchTerm) ? source : source.Where(x => FuzzyMatch(SearchTerm, x));
            return filtered
                .OrderByDescending(x => AssignedPrIds?.Contains(x.Id) == true)
                .ThenByDescending(x => x.UpdatedAt)
                .ToList();
        }
    }

    private static bool FuzzyMatch(string term, PullRequest x)
    {
        var haystack = string.Join(' ',
            x.Status.ToString(),
            x.Id,
            x.Title,
            x.Description ?? "",
            x.Creator.Name,
            x.Source.Repository,
            x.Source.Branch,
            x.Target.Branch,
            string.Join(' ', x.Reviewers.Select(r => r.User.Name)),
            string.Join(' ', x.Assignees.Select(a => a.Name)),
            x.Reviewers.Count == 0 && x.Assignees.Count == 0 ? "unassigned" : ""
        ).ToLowerInvariant();
        return term.ToLowerInvariant().Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .All(w => haystack.Contains(w));
    }

    private async Task OnRowClick(DataGridRowClickEventArgs<PullRequest> args)
    {
        if (args.Item?.Url is { } url)
            await JS.InvokeVoidAsync("open", url, "_blank");
    }

    private static readonly MarkdownPipeline _mdPipeline = new MarkdownPipelineBuilder()
        .UseAutoLinks()
        .UseTaskLists()
        .UseSoftlineBreakAsHardlineBreak()
        .UseImagePlaceholders()
        .Build();

    private static readonly System.Text.RegularExpressions.Regex _imgTagRegex =
        new(@"<img\b[^>]*/?>",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase |
            System.Text.RegularExpressions.RegexOptions.Compiled);

    private static readonly System.Text.RegularExpressions.Regex _altAttrRegex =
        new(@"\balt=""(?<alt>[^""]*)""",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase |
            System.Text.RegularExpressions.RegexOptions.Compiled);

    private static string RenderMarkdown(string markdown)
    {
        var html = Markdig.Markdown.ToHtml(markdown, _mdPipeline);
        return _imgTagRegex.Replace(html, m =>
        {
            var altMatch = _altAttrRegex.Match(m.Value);
            var label = altMatch.Success && !string.IsNullOrWhiteSpace(altMatch.Groups["alt"].Value)
                ? altMatch.Groups["alt"].Value
                : "image";
            return $"<span class=\"pr-image-placeholder\">&#x1F5BC; {System.Net.WebUtility.HtmlEncode(label)}</span>";
        });
    }

    private static string Relative(DateTimeOffset dt)
    {
        var d = DateTimeOffset.UtcNow - dt;
        if (d.TotalDays >= 1) return $"{(int)d.TotalDays}d ago";
        if (d.TotalHours >= 1) return $"{(int)d.TotalHours}h ago";
        return $"{(int)d.TotalMinutes}m ago";
    }
}
