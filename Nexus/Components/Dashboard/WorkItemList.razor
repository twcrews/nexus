<MudDataGrid Elevation="0" Class="bordered" T="WorkItem" Items="@_items" SortMode="SortMode.Multiple" Hover="true" Dense="true">
    <NoRecordsContent>
        <MudText Typo="Typo.body2" Style="opacity:0.5;padding:1rem;">No work items.</MudText>
    </NoRecordsContent>
    <Columns>
        <TemplateColumn T="WorkItem" Title="Type" SortBy="@(x => x.Type)">
            <CellTemplate>
                <MudChip T="string" Text="@SplitPascal(context.Item.Type)"
                         Color="@TypeColor(context.Item.Type)"
                         Variant="Variant.Filled" Size="Size.Small" />
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn T="WorkItem" Title="ID" SortBy="@(x => x.Id)">
            <CellTemplate>
                <span style="font-size:0.75rem;font-family:'JetBrains Mono',monospace;opacity:0.6;">
                    @context.Item.Id
                </span>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn T="WorkItem" Title="Title" SortBy="@(x => x.Title)">
            <CellTemplate>
                <MudStack Spacing="1">
                    <ScrollText>@context.Item.Title</ScrollText>
                    @if (context.Item.Labels.Count > 0)
                    {
                        <MudStack Row="true" Spacing="1" Style="flex-wrap:wrap;">
                            @foreach (var label in context.Item.Labels)
                            {
                                <MudChip T="string" Text="@label" Color="Color.Default"
                                         Variant="Variant.Outlined" Size="Size.Small"
                                         Style="font-size:0.65rem;height:18px;" />
                            }
                        </MudStack>
                    }
                </MudStack>
            </CellTemplate>
        </TemplateColumn>
        @if (ShowAssignee)
        {
            <TemplateColumn T="WorkItem" Title="Assignee" Sortable="false">
                <CellTemplate>
                    @if (context.Item.Assignee is not null)
                    {
                        <UserPill User="context.Item.Assignee" />
                    }
                    else
                    {
                        <span style="opacity:0.35;">—</span>
                    }
                </CellTemplate>
            </TemplateColumn>
        }
        <TemplateColumn T="WorkItem" Title="Status" SortBy="@(x => x.Status)">
            <CellTemplate>
                <MudChip T="string" Text="@SplitPascal(context.Item.Status)"
                         Color="@StatusColor(context.Item.Status)"
                         Variant="Variant.Filled" Size="Size.Small" />
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn T="WorkItem" Title="Updated" SortBy="@(x => x.UpdatedAt)">
            <CellTemplate>
                <span style="font-size:0.75rem;opacity:0.6;">@Relative(context.Item.UpdatedAt)</span>
            </CellTemplate>
        </TemplateColumn>
    </Columns>
</MudDataGrid>

@code {
    [Parameter, EditorRequired] public IEnumerable<WorkItem>? Items { get; set; }
    [Parameter] public bool ShowAssignee { get; set; } = true;

    private List<WorkItem> _items => Items?.ToList() ?? [];

    private static string SplitPascal<T>(T value) where T : Enum
    {
        var sb = new System.Text.StringBuilder();
        foreach (var ch in value.ToString()!)
        {
            if (char.IsUpper(ch) && sb.Length > 0) sb.Append(' ');
            sb.Append(ch);
        }
        return sb.ToString();
    }

    private static Color TypeColor(WorkItemType t) => t switch
    {
        WorkItemType.Bug       => Color.Error,
        WorkItemType.Task      => Color.Info,
        WorkItemType.UserStory => Color.Primary,
        WorkItemType.Feature   => Color.Success,
        WorkItemType.Epic      => Color.Warning,
        _                      => Color.Default,
    };

    private static Color StatusColor(WorkItemStatus s) => s switch
    {
        WorkItemStatus.New                                        => Color.Info,
        WorkItemStatus.Active or WorkItemStatus.InProgress        => Color.Primary,
        WorkItemStatus.Resolved                                   => Color.Success,
        WorkItemStatus.Closed                                     => Color.Default,
        WorkItemStatus.Blocked                                    => Color.Error,
        _                                                         => Color.Secondary,
    };

    private static string Relative(DateTimeOffset dt)
    {
        var d = DateTimeOffset.UtcNow - dt;
        if (d.TotalDays >= 1)  return $"{(int)d.TotalDays}d ago";
        if (d.TotalHours >= 1) return $"{(int)d.TotalHours}h ago";
        return $"{(int)d.TotalMinutes}m ago";
    }
}
