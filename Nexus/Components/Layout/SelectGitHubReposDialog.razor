@inject SessionTokenStore TokenStore
@inject IHttpClientFactory HttpFactory
@inject ISnackbar Snackbar

<MudDialog Style="max-height:85vh;">
    <DialogContent>
        <MudStack Spacing="3" Style="padding:0.5rem 0;">
            @if (_loading)
            {
                <MudStack AlignItems="AlignItems.Center" Style="padding:2rem 0;">
                    <MudProgressCircular Indeterminate="true" />
                    <MudText Typo="Typo.body2" Style="opacity:0.6;">Loading repositories…</MudText>
                </MudStack>
            }
            else
            {
                <MudText Typo="Typo.body2" Style="opacity:0.6;">
                    Choose which repositories Nexus will monitor for
                    <strong>@Token.DisplayName</strong>.
                </MudText>

                @* User's own repos *@
                @if (_userRepos.Count > 0)
                {
                    var userRepoNames = _userRepos.Select(r => r.FullName).ToList();
                    var userRepoNameSet = new HashSet<string>(userRepoNames, StringComparer.OrdinalIgnoreCase);
                    var remainingUserRepos = userRepoNames.Where(r => !_selected.Contains(r) && !_monitoredElsewhere.ContainsKey(r)).ToList();
                    var availableUserRepos = remainingUserRepos.Where(r => FuzzyMatch(_userRepoSearch, ShortName(r))).ToList();
                    var selectedUserRepos = _selected.Where(r => userRepoNameSet.Contains(r)).ToList();
                    var allUserReposSelectable = !userRepoNames.Any(r => !_selected.Contains(r) && !_monitoredElsewhere.ContainsKey(r));

                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        @if (!string.IsNullOrEmpty(Token.AvatarUrl))
                        {
                            <MudAvatar Color="Color.Dark" Size="Size.Small" Style="width:20px;height:20px;">
                                <MudImage Src="@Token.AvatarUrl" Alt="@Token.DisplayName" />
                            </MudAvatar>
                        }
                        <MudText Typo="Typo.button">Your repositories</MudText>
                    </MudStack>
                    @if (!allUserReposSelectable && remainingUserRepos.Count > 1)
                    {
                        <MudTextField T="string" @bind-Value="_userRepoSearch" Placeholder="Search repositories…"
                                      Immediate="true" Clearable="true" Margin="Margin.Dense"
                                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" />
                    }
                    @if (availableUserRepos.Count > 0)
                    {
                        <MudPaper Outlined="true" Style="max-height:140px;overflow-y:auto;">
                            <MudList T="string" Dense="true">
                                @foreach (var repoName in availableUserRepos)
                                {
                                    var rn = repoName;
                                    <MudListItem T="string" Dense="true" Style="cursor:pointer;"
                                                 OnClick="@(() => { _selected.Add(rn); StateHasChanged(); })">
                                        @ShortName(rn)
                                    </MudListItem>
                                }
                            </MudList>
                        </MudPaper>
                    }
                    else if (allUserReposSelectable)
                    {
                        <MudText Typo="Typo.body2" Style="opacity:0.5;">All repositories selected.</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Style="opacity:0.5;">No matches.</MudText>
                    }
                    @if (selectedUserRepos.Count > 0)
                    {
                        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Style="padding-top:2px;">
                            @foreach (var repo in selectedUserRepos)
                            {
                                var r = repo;
                                <MudChip T="string" Size="Size.Small" Color="Color.Primary"
                                         OnClose="@(_ => { _selected.Remove(r); StateHasChanged(); })">@ShortName(r)</MudChip>
                            }
                        </MudStack>
                    }
                }

                <br />

                @* Org repos *@
                @foreach (var (org, repos) in _orgRepos)
                {
                    var orgName = org;
                    var orgRepoNames = repos.Select(r => r.FullName).ToList();
                    var orgRepoNameSet = new HashSet<string>(orgRepoNames, StringComparer.OrdinalIgnoreCase);
                    var remainingOrgRepos = orgRepoNames.Where(r => !_selected.Contains(r) && !_monitoredElsewhere.ContainsKey(r)).ToList();
                    var orgSearch = _orgRepoSearches.GetValueOrDefault(orgName, "");
                    var availableOrgRepos = remainingOrgRepos.Where(r => FuzzyMatch(orgSearch, ShortName(r))).ToList();
                    var selectedOrgRepos = _selected.Where(r => orgRepoNameSet.Contains(r)).ToList();
                    var allOrgReposSelectable = !orgRepoNames.Any(r => !_selected.Contains(r) && !_monitoredElsewhere.ContainsKey(r));

                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        @if (_orgAvatars.TryGetValue(orgName, out var orgAvatar))
                        {
                            <MudAvatar Color="Color.Dark" Size="Size.Small">
                                <MudImage Src="@orgAvatar" Alt="@orgName" />
                            </MudAvatar>
                        }
                        <MudText Typo="Typo.button">@orgName</MudText>
                    </MudStack>
                    @if (!allOrgReposSelectable && remainingOrgRepos.Count > 1)
                    {
                        <MudTextField T="string"
                                      Value="@orgSearch"
                                      ValueChanged="@((string v) => { _orgRepoSearches[orgName] = v ?? ""; StateHasChanged(); })"
                                      Placeholder="Search repositories…"
                                      Immediate="true" Clearable="true" Margin="Margin.Dense"
                                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" />
                    }
                    @if (availableOrgRepos.Count > 0)
                    {
                        <MudPaper Outlined="true" Style="max-height:140px;overflow-y:auto;">
                            <MudList T="string" Dense="true">
                                @foreach (var repoName in availableOrgRepos)
                                {
                                    var rn = repoName;
                                    <MudListItem T="string" Dense="true" Style="cursor:pointer;"
                                                 OnClick="@(() => { _selected.Add(rn); StateHasChanged(); })">
                                        @ShortName(rn)
                                    </MudListItem>
                                }
                            </MudList>
                        </MudPaper>
                    }
                    else if (allOrgReposSelectable)
                    {
                        <MudText Typo="Typo.body2" Style="opacity:0.5;">All repositories selected.</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Style="opacity:0.5;">No matches.</MudText>
                    }
                    @if (selectedOrgRepos.Count > 0)
                    {
                        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Style="padding-top:2px;">
                            @foreach (var repo in selectedOrgRepos)
                            {
                                var r = repo;
                                <MudChip T="string" Size="Size.Small" Color="Color.Primary"
                                         OnClose="@(_ => { _selected.Remove(r); StateHasChanged(); })">@ShortName(r)</MudChip>
                            }
                        </MudStack>
                    }
                }

                <br />

                @* Live search for repos not in any local list *@
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Custom.Brands.GitHub" Size="Size.Small" />
                    <MudText Typo="Typo.button">Public Repositories</MudText>
                </MudStack>
                <MudAutocomplete T="string"
                                 Placeholder="owner/repo"
                                 SearchFunc="@SearchReposAsync"
                                 ValueChanged="@AddSearchResult"
                                 ResetValueOnEmptyText="true"
                                 CoerceText="false"
                                 Immediate="true"
                                 DebounceInterval="300"
                                 AdornmentIcon="@Icons.Material.Filled.Search"
                                 Adornment="Adornment.Start"
                                 Variant="Variant.Outlined"
                                 Dense="true" />

                @* Chips for repos added via search (not in any local list) *@
                @if (SearchAddedRepos.Count > 0)
                {
                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                        @foreach (var repo in SearchAddedRepos)
                        {
                            var r = repo;
                            <MudChip T="string" Size="Size.Small" Color="Color.Secondary"
                                     OnClose="@(_ => { _selected.Remove(r); StateHasChanged(); })">@r</MudChip>
                        }
                    </MudStack>
                }
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="@Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@SaveAsync" Disabled="@_loading">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter, EditorRequired] public GitHubAccountToken Token { get; set; } = default!;

    private bool _loading = true;
    private List<GitHubRepoDto> _userRepos = [];
    private Dictionary<string, List<GitHubRepoDto>> _orgRepos = [];
    private HashSet<string> _selected = [];

    // Maps repo full name → login of the other account monitoring it.
    private Dictionary<string, string> _monitoredElsewhere = [];

    private Dictionary<string, string> _orgAvatars = new(StringComparer.OrdinalIgnoreCase);
    private string _userRepoSearch = "";
    private Dictionary<string, string> _orgRepoSearches = new(StringComparer.OrdinalIgnoreCase);

    private List<string> SearchAddedRepos
    {
        get
        {
            var local = _userRepos.Select(r => r.FullName)
                .Concat(_orgRepos.Values.SelectMany(rl => rl.Select(r => r.FullName)))
                .ToHashSet(StringComparer.OrdinalIgnoreCase);
            return [.._selected.Where(r => !local.Contains(r)).OrderBy(r => r)];
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _selected = [..Token.MonitoredRepos];
        _monitoredElsewhere = BuildMonitoredElsewhere();

        var client = CreateClient();
        try
        {
            var userReposTask = FetchUserReposAsync(client);
            var orgsTask = FetchOrgsAsync(client);
            await Task.WhenAll(userReposTask, orgsTask);
            _userRepos = await userReposTask;

            var orgRepos = new Dictionary<string, List<GitHubRepoDto>>();
            var orgs = await orgsTask;
            foreach (var org in orgs)
                if (!string.IsNullOrEmpty(org.AvatarUrl))
                    _orgAvatars[org.Login] = org.AvatarUrl;
            var orgTasks = orgs.Select(async org =>
            {
                var repos = await FetchOrgReposAsync(client, org.Login);
                return (org.Login, repos);
            });
            foreach (var (orgLogin, repos) in await Task.WhenAll(orgTasks))
                orgRepos[orgLogin] = repos;
            _orgRepos = orgRepos;
        }
        finally
        {
            _loading = false;
        }
    }

    private HttpClient CreateClient()
    {
        var client = HttpFactory.CreateClient("GitHub");
        client.DefaultRequestHeaders.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", Token.PersonalAccessToken);
        return client;
    }

    private Dictionary<string, string> BuildMonitoredElsewhere()
    {
        var result = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        var allAccounts = TokenStore.GetLinkedAccounts();
        foreach (var account in allAccounts.GitHubAccounts.Where(a => a.Login != Token.Login))
            foreach (var repo in account.MonitoredRepos)
                result.TryAdd(repo, account.Login);
        return result;
    }

    private void AddSearchResult(string? fullName)
    {
        if (string.IsNullOrWhiteSpace(fullName)) return;
        if (_monitoredElsewhere.TryGetValue(fullName, out var otherLogin))
        {
            Snackbar.Add($"{fullName} is already monitored by @{otherLogin}", Severity.Warning);
            return;
        }
        _selected.Add(fullName);
    }

    private async Task SaveAsync()
    {
        await TokenStore.UpdateGitHubMonitoredReposAsync(Token.Login, [.._selected]);
        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();

    private static string ShortName(string fullName)
    {
        var slash = fullName.IndexOf('/');
        return slash >= 0 ? fullName[(slash + 1)..] : fullName;
    }

    private static bool FuzzyMatch(string query, string target)
    {
        if (string.IsNullOrEmpty(query)) return true;
        int qi = 0;
        foreach (char tc in target)
        {
            if (char.ToLowerInvariant(tc) == char.ToLowerInvariant(query[qi]))
                if (++qi == query.Length) return true;
        }
        return false;
    }

    // --- GitHub API calls ---

    private static readonly System.Text.Json.JsonSerializerOptions _jsonOpts = System.Text.Json.JsonSerializerOptions.Web;

    private async Task<List<GitHubRepoDto>> FetchUserReposAsync(HttpClient client)
    {
        try
        {
            return await client.GetFromJsonAsync<List<GitHubRepoDto>>(
                "user/repos?per_page=100&sort=updated&affiliation=owner", _jsonOpts)
                ?? [];
        }
        catch { return []; }
    }

    private async Task<List<GitHubOrgDto>> FetchOrgsAsync(HttpClient client)
    {
        try
        {
            return await client.GetFromJsonAsync<List<GitHubOrgDto>>("user/orgs?per_page=100", _jsonOpts) ?? [];
        }
        catch { return []; }
    }

    private async Task<List<GitHubRepoDto>> FetchOrgReposAsync(HttpClient client, string org)
    {
        try
        {
            return await client.GetFromJsonAsync<List<GitHubRepoDto>>(
                $"orgs/{Uri.EscapeDataString(org)}/repos?per_page=100&sort=updated", _jsonOpts)
                ?? [];
        }
        catch { return []; }
    }

    private async Task<IEnumerable<string>> SearchReposAsync(string text, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(text) || text.Length < 2) return [];
        try
        {
            var url = $"search/repositories?q={Uri.EscapeDataString(text)}+fork:false&per_page=10";
            var result = await CreateClient().GetFromJsonAsync<GitHubRepoSearchDto>(url, _jsonOpts, ct);
            return result?.Items.Select(r => r.FullName) ?? [];
        }
        catch { return []; }
    }

    // --- JSON models (used only in this dialog) ---

    private record GitHubRepoDto(
        [property: System.Text.Json.Serialization.JsonPropertyName("full_name")] string FullName,
        [property: System.Text.Json.Serialization.JsonPropertyName("description")] string? Description,
        [property: System.Text.Json.Serialization.JsonPropertyName("private")] bool Private);

    private record GitHubOrgDto(
        [property: System.Text.Json.Serialization.JsonPropertyName("login")] string Login,
        [property: System.Text.Json.Serialization.JsonPropertyName("avatar_url")] string? AvatarUrl);

    private record GitHubRepoSearchDto(
        [property: System.Text.Json.Serialization.JsonPropertyName("total_count")] int TotalCount,
        [property: System.Text.Json.Serialization.JsonPropertyName("items")] List<GitHubRepoDto> Items);
}
