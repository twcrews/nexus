@page "/"
@page "/{**path}"
@using Microsoft.AspNetCore.WebUtilities
@using System.Text
@using System.Text.Json
@inject RefreshService RefreshService
@inject SessionTokenStore TokenStore
@inject IDialogService DialogService
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<MudThemeProvider @ref="_mudThemeProvider" Theme="_theme"
    IsDarkMode="IsDarkMode" IsDarkModeChanged="@(v => { _systemIsDark = v; StateHasChanged(); })"
    ObserveSystemDarkModeChange="@(_themePreference == ThemePreference.System)" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<CascadingValue Value="IsDarkMode" Name="IsDarkMode">
    <MudLayout>
        <MudAppBar Dense Elevation="0" Style="border-bottom: 1px solid var(--mud-palette-divider);">
            <div style="height: 100%; padding: 8px;">
                <Wordmark/>
            </div>
            <MudSpacer />
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                @if (RefreshService.LastRefreshed.HasValue)
                {
                    <MudText Typo="Typo.caption">
                        last refreshed at @(RefreshService.LastRefreshed!.Value.ToLocalTime().ToString("h:mm tt"))
                    </MudText>
                }
                <MudIconButton Icon="@Icons.Material.Filled.Settings" Size="Size.Small" OnClick="@OpenSettingsDialog" />
            </MudStack>
        </MudAppBar>
        <MudMainContent>
            <ErrorBoundary>
                <Home />
            </ErrorBoundary>
        </MudMainContent>
    </MudLayout>
</CascadingValue>

@code {
    private ThemePreference _themePreference = ThemePreference.System;
    private bool _systemIsDark = true;
    private MudThemeProvider? _mudThemeProvider;

    private bool IsDarkMode => _themePreference switch
    {
        ThemePreference.Dark => true,
        ThemePreference.Light => false,
        _ => _systemIsDark
    };

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            // Brand
            Primary = "#3A6EF0",
            PrimaryDarken = "#2853A4",
            PrimaryLighten = "#3290FE",
            Secondary = "#1ABFA3",
            SecondaryDarken = "#128F7A",
            Tertiary = "#F0883E",
            // Semantic
            Success = "#16A34A",
            Warning = "#D97706",
            Error = "#DC2626",
            Info = "#3A6EF0",
            // Backgrounds
            Background = "#F8F9FC",
            Surface = "#FFFFFF",
            DrawerBackground = "#EEF1F8",
            AppbarBackground = "#FFFFFF",
            // Text
            TextPrimary = "#0F1623",
            TextSecondary = "#4A5568",
            TextDisabled = "#9AABBF",
            // Borders / dividers
            Divider = "#D1D9E6",
            DividerLight = "#E0E5F0",
            TableLines = "#D1D9E6",
            LinesDefault = "#D1D9E6",
            LinesInputs = "#A0AEBE",
            ActionDefault = "#4A5568",
            AppbarText = "#0F1623",
        },
        PaletteDark = new PaletteDark
        {
            // Brand
            Primary = "#3A6EF0",
            PrimaryDarken = "#2853A4",
            PrimaryLighten = "#3290FE",
            Secondary = "#1ABFA3",
            SecondaryDarken = "#128F7A",
            Tertiary = "#F0883E",
            // Semantic
            Success = "#4ADE80",
            Warning = "#FBB346",
            Error = "#F87171",
            Info = "#6B96F5",
            // Backgrounds
            Background = "#0D1117",
            Surface = "#161B27",
            DrawerBackground = "#1C2333",
            AppbarBackground = "#161B27",
            // Text
            TextPrimary = "#E8EEFA",
            TextSecondary = "#8B9EC4",
            TextDisabled = "#4A5A78",
            // Borders / dividers
            Divider = "#2A3550",
            DividerLight = "#242D3E",
            TableLines = "#2A3550",
            LinesDefault = "#2A3550",
            LinesInputs = "#3D4F6E",
            ActionDefault = "#8B9EC4",
            AppbarText = "#E8EEFA",
        },
        Typography = new Typography
        {
            Default = new DefaultTypography { FontFamily = ["Inter", "sans-serif"], FontWeight = "400" },
            H1 = new H1Typography { FontFamily = ["Inter", "sans-serif"], FontWeight = "700" },
            H2 = new H2Typography { FontFamily = ["Inter", "sans-serif"], FontWeight = "700" },
            H3 = new H3Typography { FontFamily = ["Inter", "sans-serif"], FontWeight = "600" },
            H4 = new H4Typography { FontFamily = ["Inter", "sans-serif"], FontWeight = "600" },
            H5 = new H5Typography { FontFamily = ["Inter", "sans-serif"], FontWeight = "600" },
            H6 = new H6Typography { FontFamily = ["Inter", "sans-serif"], FontWeight = "600" },
            Subtitle1 = new Subtitle1Typography { FontFamily = ["Inter", "sans-serif"], FontWeight = "500" },
            Subtitle2 = new Subtitle2Typography { FontFamily = ["Inter", "sans-serif"], FontWeight = "500" },
            Body1 = new Body1Typography { FontFamily = ["Inter", "sans-serif"], FontWeight = "400" },
            Body2 = new Body2Typography { FontFamily = ["Inter", "sans-serif"], FontWeight = "400" },
            Caption = new CaptionTypography { FontFamily = ["Inter", "sans-serif"], FontWeight = "400" },
            Overline = new OverlineTypography { FontFamily = ["JetBrains Mono", "monospace"], FontWeight = "400" },
            Button = new ButtonTypography { FontFamily = ["Inter", "sans-serif"], FontWeight = "500" },
        }
    };

    protected override void OnInitialized()
    {
        TokenStore.AccountsChanged += OnAccountsChanged;
        RefreshService.Refreshed += OnRefreshed;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await HandleGitHubCallbackAsync();
            var saved = await JS.InvokeAsync<string?>("localStorage.getItem", "nexus.theme");
            if (saved == "dark") _themePreference = ThemePreference.Dark;
            else if (saved == "light") _themePreference = ThemePreference.Light;
            else
            {
                _themePreference = ThemePreference.System;
                _systemIsDark = await (_mudThemeProvider?.GetSystemDarkModeAsync() ?? Task.FromResult(_systemIsDark));
            }
            StateHasChanged();
        }
    }

    private async Task HandleGitHubCallbackAsync()
    {
        var uri = new Uri(Nav.Uri);
        if (uri.AbsolutePath.TrimEnd('/') != "/link-github")
            return;

        GitHubAccountToken? linkedToken = null;
        var query = QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("token", out var tokenValues) && tokenValues.FirstOrDefault() is string tokenStr && !string.IsNullOrEmpty(tokenStr))
        {
            try
            {
                var json = Encoding.UTF8.GetString(Convert.FromBase64String(tokenStr));
                var token = JsonSerializer.Deserialize<GitHubAccountToken>(json);
                if (token is not null)
                {
                    await TokenStore.LoadAsync();
                    await TokenStore.LinkGitHubAccountAsync(token);
                    linkedToken = token;
                }
            }
            catch
            {
                // Discard malformed token.
            }
        }

        // Navigate without a full reload so the component tree (and dialog infrastructure) stays alive.
        Nav.NavigateTo("/", forceLoad: false);

        if (linkedToken is not null)
        {
            await OpenSelectReposDialogAsync(linkedToken);
        }
    }

    private async Task OpenSelectReposDialogAsync(GitHubAccountToken token)
    {
        var parameters = new DialogParameters<SelectGitHubReposDialog>
        {
            { x => x.Token, token }
        };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = false,
            BackdropClick = false
        };
        await DialogService.ShowAsync<SelectGitHubReposDialog>("Select Repositories", parameters, options);
    }

    private async Task OpenSettingsDialog()
    {
        var parameters = new DialogParameters<SettingsDialog>
        {
            { x => x.ThemePreference, _themePreference },
            { x => x.ThemePreferenceChanged, (ThemePreference v) => { _ = ApplyThemePreferenceAsync(v); } }
        };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true,
            BackdropClick = true
        };
        await DialogService.ShowAsync<SettingsDialog>("Settings", parameters, options);
    }

    private async Task ApplyThemePreferenceAsync(ThemePreference preference)
    {
        _themePreference = preference;
        if (preference == ThemePreference.System)
        {
            _systemIsDark = await (_mudThemeProvider?.GetSystemDarkModeAsync() ?? Task.FromResult(_systemIsDark));
            await JS.InvokeVoidAsync("localStorage.removeItem", "nexus.theme");
        }
        else
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "nexus.theme", preference == ThemePreference.Dark ? "dark" : "light");
        }
        await InvokeAsync(StateHasChanged);
    }

    private void OnAccountsChanged() => InvokeAsync(StateHasChanged);

    private void OnRefreshed() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        TokenStore.AccountsChanged -= OnAccountsChanged;
        RefreshService.Refreshed -= OnRefreshed;
    }
}
