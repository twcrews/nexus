@page "/"
@page "/{**path}"
@inject RefreshService RefreshService
@inject SessionTokenStore TokenStore
@inject DialogService DialogService
@implements IDisposable

<RadzenComponents />

<RadzenLayout>
    <RadzenHeader>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                     JustifyContent="JustifyContent.SpaceBetween" Gap="8px" Style="margin-right: 8px;">
            <div style="height: 50px; padding: 8px;">
                <Wordmark />
            </div>
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="12px">
                @if (RefreshService.LastRefreshed.HasValue)
                {
                    <RadzenText TextStyle="TextStyle.Caption" style="opacity: 0.5; white-space: nowrap;">
                        refreshed @(ElapsedSeconds)s ago
                    </RadzenText>
                }
                <RadzenButton Icon="add_link"
                              Text="@LinkedAccountsLabel"
                              ButtonStyle="ButtonStyle.Light"
                              Size="ButtonSize.Small"
                              Click="@OpenLinkDialog" />
                <RadzenAppearanceToggle />
            </RadzenStack>
        </RadzenStack>
    </RadzenHeader>
    <RadzenBody>
        <ErrorBoundary>
            <Home />
        </ErrorBoundary>
    </RadzenBody>
</RadzenLayout>

@code {
    private CancellationTokenSource _cts = new();

    private int ElapsedSeconds => RefreshService.LastRefreshed.HasValue
        ? (int)Math.Floor((DateTimeOffset.UtcNow - RefreshService.LastRefreshed.Value).TotalSeconds)
        : 0;

    private string LinkedAccountsLabel
    {
        get
        {
            var count = TokenStore.GetLinkedAccounts().DummyAccounts.Count;
            return count == 0 ? "Connect account" : $"{count} account{(count == 1 ? "" : "s")}";
        }
    }

    protected override void OnInitialized()
    {
        TokenStore.AccountsChanged += OnAccountsChanged;
        _ = RunTickLoopAsync(_cts.Token);
    }

    private async Task OpenLinkDialog()
    {
        await DialogService.OpenAsync<LinkDummyAccountDialog>("Connect Dummy Account",
            options: new DialogOptions { Width = "400px", CloseDialogOnOverlayClick = true });
    }

    private void OnAccountsChanged() => InvokeAsync(StateHasChanged);

    private async Task RunTickLoopAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        while (await timer.WaitForNextTickAsync(ct))
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        TokenStore.AccountsChanged -= OnAccountsChanged;
        _cts.Cancel();
    }
}
