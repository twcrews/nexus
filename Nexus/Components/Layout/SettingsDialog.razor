@inject SessionTokenStore TokenStore
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        <MudMessageBox @ref="_unlinkConfirm" Title="Unlink account" CancelText="Cancel">
            <MessageContent>
                Are you sure you want to unlink <strong>@_unlinkTarget</strong>? This can't be undone.
            </MessageContent>
            <YesButton>
                <MudButton Variant="Variant.Filled" Color="Color.Error">Unlink</MudButton>
            </YesButton>
        </MudMessageBox>
        <MudStack Spacing="4" Style="min-width:320px;padding:0.5rem 0;">

            <MudStack Spacing="1">
                <MudText Typo="Typo.button" Style="opacity:0.5;">Appearance</MudText>
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.body1">Theme</MudText>
                    <MudToggleGroup T="ThemePreference" Value="_themePreference" ValueChanged="OnThemePreferenceChanged"
                                    Color="Color.Primary" CheckMark="false" Delimiters="false">
                        <MudToggleItem Value="ThemePreference.System" Text="System" />
                        <MudToggleItem Value="ThemePreference.Light" Text="Light" />
                        <MudToggleItem Value="ThemePreference.Dark" Text="Dark" />
                    </MudToggleGroup>
                </MudStack>
            </MudStack>

            <MudDivider />
            <MudStack Spacing="2">
                @{
                    var accounts = TokenStore.GetLinkedAccounts();
                    var hasAny = accounts.DummyAccounts.Count > 0
                        || accounts.GitHubAccounts.Count > 0
                        || accounts.MicrosoftAccounts.Count > 0;
                }
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.button" Style="opacity:0.5;">Accounts</MudText>
                    <MudStack Row="true" Spacing="1">
                        <MudButton Size="Size.Small" StartIcon="@Icons.Custom.Brands.GitHub"
                                   OnClick="@ConnectGitHubAsync">Link GitHub</MudButton>
                        <MudDivider Vertical FlexItem />
                        <MudButton Size="Size.Small" StartIcon="@Icons.Custom.Brands.MicrosoftAzure"
                                   OnClick="@ConnectMicrosoftAsync">Link Azure DevOps</MudButton>
                    </MudStack>
                </MudStack>

                <MudPaper Elevation="0" Class="bordered" Style="padding: 16px;">
                    <MudStack Spacing="6">
                        @if (!hasAny)
                        {
                            <MudText Typo="Typo.body2" Style="opacity:0.6;text-align:center;padding:1rem 0;">
                                No accounts connected.
                            </MudText>
                        }
                        else
                        {
                            <MudStack Spacing="2">
                                @if (accounts.GitHubAccounts.Count > 0)
                                {
                                    @foreach (var account in accounts.GitHubAccounts)
                                    {
                                        var login = account.Login;
                                        var repoCount = account.MonitoredRepos.Count;
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                <MudIcon Icon="@Icons.Custom.Brands.GitHub" Size="Size.Small"
                                                         Style="opacity:0.5;" />
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                    <MudText Typo="Typo.body1">@login</MudText>
                                                    <MudText Typo="Typo.caption" Style="opacity:0.5;">
                                                        @(repoCount == 0 ? "No repos" : $"{repoCount} {(repoCount == 1 ? "repo" :
                                   "repos")}")
                                                    </MudText>
                                                </MudStack>
                                            </MudStack>
                                            <MudStack Row="true" Spacing="0">
                                                <MudTooltip Text="Configure repositories">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Settings" Size="Size.Small"
                                                                   OnClick="@(() => ConfigureReposAsync(account))" />
                                                </MudTooltip>
                                                <MudTooltip Text="Unlink account">
                                                    <MudIconButton Icon="@Icons.Material.Filled.LinkOff" Size="Size.Small"
                                                                   Color="Color.Error"
                                                                   OnClick="@(() => RemoveGitHubAsync(login, account.DisplayName))" />
                                                </MudTooltip>
                                            </MudStack>
                                        </MudStack>
                                    }
                                }
                                @if (accounts.MicrosoftAccounts.Count > 0)
                                {
                                    @foreach (var account in accounts.MicrosoftAccounts)
                                    {
                                        var login = account.Login;
                                        var projectCount = account.MonitoredProjects.Count;
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                <MudIcon Icon="@Icons.Custom.Brands.MicrosoftAzure" Size="Size.Small"
                                                         Style="opacity:0.5;" />
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                    <MudText Typo="Typo.body1">@account.DisplayName</MudText>
                                                    <MudText Typo="Typo.caption" Style="opacity:0.5;">
                                                        @(projectCount == 0 ? "No projects" : $"{projectCount} {(projectCount == 1 ?
                                "project" : "projects")}")
                                                    </MudText>
                                                </MudStack>
                                            </MudStack>
                                            <MudStack Row="true" Spacing="0">
                                                <MudTooltip Text="Configure monitoring">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Settings" Size="Size.Small"
                                                                   OnClick="@(() => ConfigureAdoAsync(account))" />
                                                </MudTooltip>
                                                <MudTooltip Text="Unlink account">
                                                    <MudIconButton Icon="@Icons.Material.Filled.LinkOff" Size="Size.Small"
                                                                   Color="Color.Error"
                                                                   OnClick="@(() => RemoveMicrosoftAsync(login, account.DisplayName))" />
                                                </MudTooltip>
                                            </MudStack>
                                        </MudStack>
                                    }
                                }
                            </MudStack>
                        }
                    </MudStack>
                </MudPaper>
            </MudStack>

        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudStack Row="true" Spacing="1" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center"
                  Style="width:100%;">
            <MudText Typo="Typo.caption" Style="padding-left: 16px;color:var(--mud-palette-text-secondary);">
                Your data is never stored on the server. <MudLink Href="/privacy" Target="_blank" Typo="Typo.caption">Learn more</MudLink>
            </MudText>
            <MudButton Variant="Variant.Text" OnClick="@MudDialog.Cancel">Close</MudButton>
        </MudStack>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public ThemePreference ThemePreference { get; set; }
    [Parameter] public Action<ThemePreference> ThemePreferenceChanged { get; set; } = default!;

    private ThemePreference _themePreference;
    private MudMessageBox _unlinkConfirm = default!;
    private string _unlinkTarget = "";

    protected override void OnParametersSet() => _themePreference = ThemePreference;

    private void OnThemePreferenceChanged(ThemePreference v)
    {
        _themePreference = v;
        ThemePreferenceChanged(v);
    }

    private async Task RemoveGitHubAsync(string login, string displayName)
    {
        _unlinkTarget = displayName;
        if (await _unlinkConfirm.ShowAsync() is not true) return;
        await TokenStore.UnlinkGitHubAccountAsync(login);
        StateHasChanged();
    }

    private async Task ConnectGitHubAsync()
    {
        MudDialog.Close();
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            BackdropClick = false
        };
        var result = await DialogService.ShowAsync<LinkGitHubPatDialog>("Connect GitHub", options);
        var dialogResult = await result.Result;
        if (dialogResult is { Canceled: false } && dialogResult.Data is GitHubAccountToken token)
        {
            await TokenStore.LinkGitHubAccountAsync(token);
            await OpenSelectReposDialogAsync(token);
        }
    }

    private async Task ConnectMicrosoftAsync()
    {
        MudDialog.Close();
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            BackdropClick = false
        };
        var result = await DialogService.ShowAsync<LinkAdoPatDialog>("Connect Azure DevOps", options);
        var dialogResult = await result.Result;
        if (dialogResult is { Canceled: false } && dialogResult.Data is MicrosoftAccountToken token)
        {
            await TokenStore.LinkMicrosoftAccountAsync(token);
            await OpenSelectAdoMonitoringDialogAsync(token);
        }
    }

    private async Task OpenSelectReposDialogAsync(GitHubAccountToken token)
    {
        var parameters = new DialogParameters<SelectGitHubReposDialog>
        {
            { x => x.Token, token }
        };
        var options = new DialogOptions
        {
            CloseOnEscapeKey = false,
            BackdropClick = false
        };
        await DialogService.ShowAsync<SelectGitHubReposDialog>("Select Repositories", parameters, options);
    }

    private async Task OpenSelectAdoMonitoringDialogAsync(MicrosoftAccountToken token)
    {
        var parameters = new DialogParameters<SelectAdoMonitoringDialog>
        {
            { x => x.Token, token }
        };
        var options = new DialogOptions
        {
            CloseOnEscapeKey = false,
            BackdropClick = false
        };
        await DialogService.ShowAsync<SelectAdoMonitoringDialog>("Configure Azure DevOps", parameters, options);
    }

    private async Task RemoveMicrosoftAsync(string login, string displayName)
    {
        _unlinkTarget = displayName;
        if (await _unlinkConfirm.ShowAsync() is not true) return;
        await TokenStore.UnlinkMicrosoftAccountAsync(login);
        StateHasChanged();
    }

    private async Task ConfigureAdoAsync(MicrosoftAccountToken account)
    {
        var parameters = new DialogParameters<SelectAdoMonitoringDialog>
        {
            { x => x.Token, account }
        };
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            BackdropClick = false
        };
        await DialogService.ShowAsync<SelectAdoMonitoringDialog>("Configure Azure DevOps", parameters, options);
    }

    private async Task ConfigureReposAsync(GitHubAccountToken account)
    {
        var parameters = new DialogParameters<SelectGitHubReposDialog>
        {
            { x => x.Token, account }
        };
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            BackdropClick = false
        };
        await DialogService.ShowAsync<SelectGitHubReposDialog>("Configure Repositories", parameters, options);
    }
}
