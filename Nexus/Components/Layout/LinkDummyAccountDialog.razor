@inject SessionTokenStore TokenStore

<MudDialog>
    <DialogContent>
        <MudStack AlignItems="AlignItems.Center" Spacing="2" Style="min-width:320px;padding:0.5rem 0;">
            <MudStack AlignItems="AlignItems.Center" Spacing="1">
                <MudIcon Icon="@Icons.Material.Filled.DeveloperBoard" Style="font-size:3rem;opacity:0.5;" />
                <MudText Typo="Typo.h5" Style="margin:0;">Dummy Provider</MudText>
                <MudText Typo="Typo.body2" Style="opacity:0.6;text-align:center;margin:0;">
                    Nexus is requesting access to your account.
                </MudText>
            </MudStack>
            <MudPaper Outlined="true" Style="padding:16px;width:100%;">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.overline" Style="opacity:0.5;margin:0;">Signing in as</MudText>
                    <MudText Typo="Typo.h6" Style="margin:0;">@_accountName</MudText>
                </MudStack>
            </MudPaper>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="@Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@AuthorizeAsync">Authorize</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    private static readonly string[] Adjectives =
        ["artful", "bold", "calm", "daring", "eager", "fierce", "gentle", "heroic",
         "jolly", "keen", "lively", "mighty", "noble", "quirky", "serene", "vivid"];

    private static readonly string[] Animals =
        ["axolotl", "badger", "crane", "dingo", "egret", "falcon", "gecko", "heron",
         "ibis", "jackal", "kestrel", "lemur", "marmot", "numbat", "otter", "pangolin"];

    private readonly string _accountName = GenerateAccountName();

    private async Task AuthorizeAsync()
    {
        await TokenStore.LinkDummyAccountAsync(new DummyAccountToken(_accountName));
        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();

    private static string GenerateAccountName()
    {
        var rng = Random.Shared;
        return $"{Adjectives[rng.Next(Adjectives.Length)]}-{Animals[rng.Next(Animals.Length)]}";
    }
}
